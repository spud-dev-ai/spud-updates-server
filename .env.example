# Production: set these in Vercel → Project → Settings → Environment Variables.
# Local: copy to .env.local (never commit secrets).

# Git SHA of the latest **shipped** Spud IDE build (must match baked-in product commit).
# SPUD_LATEST_COMMIT=

# Release tag on GitHub (zip asset names / default download URL).
# SPUD_RELEASE_TAG=v0.1.0

# SPUD_GITHUB_REPO=spud-dev-ai/spud-ide

# Integrity for Electron zip (required for 200 JSON on /api/update/...; else 204).
# SPUD_UPDATE_SHA256=
# SPUD_UPDATE_SHA1=

# Optional overrides
# SPUD_UPDATE_ZIP_URL=
# SPUD_DOWNLOAD_PAGE=https://spud.dev/download
# SPUD_PRODUCT_VERSION=0.1.0
# SPUD_UPDATE_TIMESTAMP=
